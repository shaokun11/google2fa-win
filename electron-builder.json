{
  "appId": "com.google2fa.desktop",
  "productName": "Google 2FA Desktop",
  "directories": {
    "output": "dist"
  },
  "files": [
    "out/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "electron/assets",
      "to": "assets"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "Google2FA-Desktop-Setup-${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "uninstallDisplayName": "Google 2FA Desktop",
    "installerLanguages": [
      "zh_CN",
      "en_US"
    ],
    "language": 2052,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Google 2FA Desktop"
  }
}